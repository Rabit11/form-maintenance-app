# 复制为 .env 使用（docker compose 自动读取）
# 对外端口
SRPM_PORT=8787
# 构建加速（国内镜像源，默认已启用；海外服务器可改回官方源）
NPM_REGISTRY=https://registry.npmmirror.com
APT_MIRROR=mirrors.aliyun.com
# 智谱 GLM API 密钥（AI 文档识读；留空则为本地模拟解析）
GLM_API_KEY=
AI_PROVIDER=openai
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_MODEL=glm-5.2

# ---------- 数据库备份（方案 Phase A）----------
# 容器内路径；宿主机对应：<项目根>/backups
BACKUP_DIR=/app/server/backups
# 备份文件名前缀环境标签
BACKUP_ENV=prod114
# 1=gzip 压缩；0=仅 .db
BACKUP_GZIP=1
# 设为 0 可关闭启动后定时日备检查
# BACKUP_SCHEDULER=0
